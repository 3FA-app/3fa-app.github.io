---
import Base from '../layouts/Base.astro';

// Configured base without its trailing slash, for prefixing internal links.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Not found — 3FA" description="Page not found.">
  <section style="text-align:center; padding:64px 0;">
    <h1>404</h1>
    <p class="lede">That page doesn't exist.</p>
    <p style="margin-top:24px;">
      <a href={base || '/'} style="color:#5d9cff;">← Back home</a>
      &nbsp;·&nbsp;
      <a href={`${base}/download`} style="color:#5d9cff;">Download 3FA</a>
    </p>
  </section>
</Base>
