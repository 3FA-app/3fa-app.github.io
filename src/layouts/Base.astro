---
const {
  title = '3FA — Secure Desktop Authenticator',
  description = '3FA is a highly secure, native desktop authenticator: TOTP/HOTP codes locked behind passcode, biometrics, passkey, and voice — with zero-knowledge sync.',
} = Astro.props;

// Canonical URL resolved against the configured `site`.
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://threefa.app').href;

// Configured base without its trailing slash, for prefixing internal links.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="theme-color" content="#16161c" />
    <meta name="referrer" content="no-referrer" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="3FA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header>
      <a href={base || '/'} class="brand">3FA</a>
      <nav>
        <a href={`${base}/security`}>Security</a>
        <a href={`${base}/download`}>Download</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <span>3FA Authenticator</span>
      <span>· Native Rust · Zero-knowledge sync</span>
    </footer>

    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: #16161c; color: #e8eaf0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.55;
      }
      header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 18px 32px; border-bottom: 1px solid #23232c;
      }
      .brand { font-weight: 700; font-size: 20px; color: #5d9cff; text-decoration: none; }
      nav a { color: #aeb4c2; text-decoration: none; margin-left: 22px; }
      nav a:hover { color: #fff; }
      main { max-width: 880px; margin: 0 auto; padding: 48px 24px; }
      footer {
        text-align: center; color: #6b7180; padding: 32px; font-size: 13px;
        border-top: 1px solid #23232c; display: flex; gap: 8px; justify-content: center;
      }
      h1 { font-size: 40px; line-height: 1.1; margin: 0 0 16px; }
      h2 { font-size: 24px; margin-top: 48px; }
      .lede { font-size: 19px; color: #c7ccd6; }
    </style>
  </body>
</html>
